# ============================================================
# Application Fond de Caisse - Variables d'environnement
# ============================================================
# Copier ce fichier en .env et remplir les valeurs.
# Ne JAMAIS committer .env (deja dans .gitignore)

# --- Application ---
NODE_ENV=development
APP_PORT=3000
APP_NAME=fdc-backend
API_PREFIX=api/v1

# --- Base de donnees (SQL Server) ---
DB_HOST=10.10.32.2
DB_PORT=1433
DB_USER=npg_user
DB_PASS=change_me
DB_NAME=npg_gestion_caisse
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_SYNCHRONIZE=false
DB_LOGGING=true

# --- JWT ---
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_too_to_a_random_64_char_string
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logs ---
LOG_LEVEL=debug
